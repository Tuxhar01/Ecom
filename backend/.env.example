# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-here-change-in-production
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///bookstore.db

# AIRA Integration (REQUIRED - Replace with your actual webhook URL)
AIRA_WEBHOOK_URL=http://localhost:8000/webhook

# CORS
FRONTEND_URL=http://localhost:5173

# Optional AIRA Settings
AIRA_ENABLED=true
AIRA_LOG_LEVEL=ERROR
AIRA_MAX_RETRIES=3
AIRA_TIMEOUT=5
AIRA_RATE_LIMIT=100